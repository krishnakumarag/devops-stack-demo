pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    options {
        skipStagesAfterUnstable()
    }

    environment {
        SERVER_USER = 'devops'
        SERVER_HOST = '172.17.0.2'
        SERVER_PORT = '22'
        JAR_NAME    = 'demo-0.0.1-SNAPSHOT.jar'
        DEPLOY_DIR  = '/app'
        APP_PORT    = '8082'
    }

    stages {
        stage('Build') {
            steps {
                sh 'mvn -f app/pom.xml -B -DskipTests clean package'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn -f app/pom.xml test'
            }
            post {
                always {
                    junit 'app/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Copy JAR to Server') {
            steps {
                sshagent(['app-server-ssh']) {
                    sh '''
                        # Create deploy directory on server
                        ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${SERVER_HOST} "mkdir -p ${DEPLOY_DIR}"

                        # Copy JAR to server
                        scp -o StrictHostKeyChecking=no \
                            app/target/${JAR_NAME} \
                            ${SERVER_USER}@${SERVER_HOST}:${DEPLOY_DIR}/app.jar

                        echo "JAR copied successfully to ${SERVER_HOST}:${DEPLOY_DIR}/app.jar"
                    '''
                }
            }
        }

        stage('Deploy on Server') {
            steps {
                sshagent(['app-server-ssh']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${SERVER_HOST} bash << 'ENDSSH'
                            # Kill existing app
                            kill $(cat /tmp/app.pid) 2>/dev/null || true
                            sleep 2

                            # Start app in background
                            nohup java -jar /app/app.jar --server.port=8082 > /tmp/app.log 2>&1 &
                            echo $! > /tmp/app.pid

                            echo "App started with PID $(cat /tmp/app.pid)"
ENDSSH
                    '''
                }
            }
        }

        stage('Verify') {
            steps {
                sshagent(['app-server-ssh']) {
                    sh '''
                        sleep 15
                        ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${SERVER_HOST} \
                            "curl http://localhost:${APP_PORT}/actuator/health"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment successful — app is running on app-server!'
        }
        failure {
            echo 'Pipeline failed — check logs above.'
        }
    }
}